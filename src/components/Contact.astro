---
    import Titulo from "./Titulo.astro";
    import ContactCard from "./ContactCard.astro";
    import InputContact from "./InputContact.astro";
---

<section class="min-h-screen bg-black" id="contact">
    <Titulo title="Contáctame" />
    <div class="flex flex-wrap gap-20 justify-center">
        <!-- Formulario -->
        <div class="text-gray-400 pl-6 text-md gap-5">
            <h3 class="text-white text-3xl mb-8">Enviame un mensaje</h3>

            <!-- TODO: Terminar los estilos -->
            <form action="" class="flex flex-col gap-5">

                <!-- TODO: Cambia todos los input al componente InputContact -->
                <label for="nombre" class="flex gap-2 flex-col">Nombre
                    <input type="text" id="nombre" placeholder="Tu nombre"
                    class="bg-zinc-900 px-2 py-3 rounded-lg"/>
                </label>

                <label for="email" class="flex gap-2 flex-col">Email
                    <input type="email" id="email" placeholder="name@example.com"
                    class="bg-zinc-900 px-2 py-3 rounded-lg"/>
                </label>

                <label for="tema" class="flex gap-2 flex-col">Tema
                    <input type="text" id="tema" placeholder="Escribe el tema..."
                    class="bg-zinc-900 px-2 py-3 rounded-lg"/>
                </label>

                <label for="mensaje" class="flex gap-2 flex-col">Mensaje
                    <textarea name="mensaje" id="" placeholder="Escribe tu mensaje..."
                    class="bg-zinc-900 px-2 py-3 rounded-lg"></textarea>
                </label>

                <button type="submit" 
                        class="bg-blue-500 p-2 rounded text-white
                        hover:bg-blue-700 transition-colors">
                            Enviar
                </button>
            </form>
        </div>

        <!-- Telefono, email, localizacion, etc -->
        <div>
            <h3 class="text-white text-3xl mb-8">Información de contacto</h3>
            <ContactCard logo="" tipo="email" info="c.estebandiez@gmail.com" />
        </div>
    </div>
</section>