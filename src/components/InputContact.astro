---
const { label, placeholder, name } = Astro.props;
---

<label for={name} class="flex gap-2 flex-col">
    <span class="text-sm">{label}</span>
    <input
        type="text"
        id={name}
        placeholder={placeholder}
        name={name}
        required
        class="bg-zinc-900 px-3 py-2.5 rounded-lg focus:outline-blue-500 focus:outline w-full text-sm"
    />
</label>
