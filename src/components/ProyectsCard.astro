---

    const { foto, title, descripcion, tecnologias, enlace } = Astro.props;

---


<section class="group overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/60 shadow-[0_10px_30px_rgba(0,0,0,0.35)]
                hover:border-blue-500 transition-all duration-300 hover:scale-105">
    <div class="relative aspect-video overflow-hidden">
        <img
            src={foto}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-300"
        />
        <div class="pointer-events-none absolute inset-0 bg-linear-to-t from-zinc-950/90 via-zinc-950/30 to-transparent"></div>
    </div>
    <div class="p-6">
        <h4 class="text-lg font-semibold text-white">{title}</h4>
        <p class="mt-2 text-sm leading-6 text-zinc-400">{descripcion}</p>
        <div class="mt-4 flex flex-wrap gap-2">
            <!-- Tengo que tipar tecnologia pq astro usar typescript -->
            {tecnologias.map((tecnologia: string) => (
                <span class="inline-flex items-center rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-zinc-300
                            hover:border-blue-500 transition-colors duration-200 hover:text-blue-500">
                    {tecnologia}
                </span>
            ))}
        </div>

        <div class="mt-5">
            <a
                href={enlace}
                target="_blank"
                class="inline-flex items-center gap-2 text-sm font-medium text-white hover:text-blue-400 transition-colors duration-200"
                rel="noreferrer"
            >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4 fill-current">
                    <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
                </svg>
                <span>Repositorio</span>
            </a>
        </div>
    </div>
</section>