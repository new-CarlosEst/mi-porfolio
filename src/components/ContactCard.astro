---
const { logo, tipo, info } = Astro.props;
---

<section
    class="group bg-zinc-900 border border-transparent rounded-lg flex justify-start gap-4 py-4 px-5 w-full
                hover:border-blue-500 transition-all duration-200"
>
    <!-- Logo del tipo de contacto -->
    <div
        class="w-12 h-12 flex items-center justify-center bg-blue-500/20 rounded-lg shrink-0
                group-hover:bg-blue-500/30 transition-colors duration-200"
    >
        <img src={logo} alt={`${tipo}-foto`} class="w-6 h-6" />
    </div>

    <!-- Informacion del contacto -->
    <div class="flex flex-col justify-center min-w-0">
        <h5 class="text-gray-400 font-normal text-xs mb-0.5">
            {tipo}
        </h5>
        <p class="text-white text-sm font-medium wrap-break-word">
            {info}
        </p>
    </div>
</section>
