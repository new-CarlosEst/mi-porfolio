---

---

<main
    class="min-h-screen relative bg-gradient-to-tl from-blue-900 via-1% via-blue-950 to-black"
>
    <!-- aqui va el patron de puntos del fondo, en un div separado del contenido -->
    <div class="absolute inset-0 opacity-10 z-2">
        <div
            class="absolute inset-0"
            style="background-image: radial-gradient(circle at 1px 1px, rgb(59, 130, 246) 1px, transparent 1px); background-size: 40px 40px"
        >
        </div>
    </div>

    <div class="relative flex items-center justify-center h-screen flex-col gap-6 font-sans z-3">
        <p class="text-blue-500 bg-blue-900/20 border border-blue-500/30 rounded-full px-4 py-2">
            Bienvenido a mi portfolio
        </p>

        <h2 class="text-5xl  font-bold text-white">
            Hola, mi nombre es 
            <span class="text-blue-500">Carlos Esteban</span>
        </h2>
        <h3 class="text-2xl text-gray-400/80">
            Desarrollador Web full stack
        </h3>

        <p class="text-gray-400/80 w-1/4 text-center">
            Estudiante de desarrollo web con ganas de aprender nuevas tecnologías y ampliar mis conocimientos y habilidades
        </p>
        <!-- TODO Hacer las pills con linkedin, ig, github, infojobs, stackoverflow -->
        <div class="flex gap-4 font-medium">
            <button class="bg-blue-500 text-white rounded px-4 py-2 hover:bg-blue-700 transition-colors">Descargar CV</button>
            <button class="rounded px-4 py-2 border border-gray-500 bg-transparent text-white hover:bg-gray-500/20 transition-colors">Contactame</button>
        </div>
    </div>
</main>
