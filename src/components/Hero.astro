---
import Media from "./Media.astro";

//Para usar los svg hago el import a una variable
import GithubIcon from "../assets/Github.svg";
import LinkedInIcon from "../assets/LinkedIn.svg";
import InstagramIcon from "../assets/Instagram.svg";
import StackoverflowIcon from "../assets/Stackoverflow.svg";
---

<main
    id="home"
    class="min-h-screen relative bg-linear-to-tl from-blue-900 via-10% via-blue-950 to-black overflow-hidden"
>
    <!-- aqui va el patron de puntos del fondo, en un div separado del contenido -->
    <div class="absolute inset-0 opacity-10 z-10">
        <div
            class="absolute inset-0"
            style="background-image: radial-gradient(circle at 2px 2px, rgb(70, 135, 239) 1px, transparent 1px); background-size: 40px 40px"
        >
        </div>
    </div>

    <!-- Contenido principal -->
    <div
        class="relative flex items-center justify-center h-screen flex-col gap-4 sm:gap-6 font-sans z-20 px-6 sm:px-8"
    >
        <!-- Bienvenida -->
        <p
            class="text-blue-500 bg-blue-900/20 border border-blue-500/30 rounded-full px-3 py-1.5 sm:px-4 sm:py-2 text-xs sm:text-sm md:text-base text-center"
        >
            Bienvenido a mi ePortfolio
        </p>

        <!-- Presentacion -->
        <h2
            class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white text-center leading-tight"
        >
            Hola, mi nombre es
            <span class="text-blue-500">Carlos Esteban</span>
        </h2>

        <!-- Rol software -->
        <h3 class="text-lg sm:text-xl md:text-2xl text-gray-400/80 text-center">
            Desarrollador Web full stack
        </h3>

        <!-- Breve descripcion -->
        <p
            class="text-gray-400/80 w-11/12 sm:w-3/4 md:w-2/3 lg:w-1/2 xl:w-1/3 text-center text-sm sm:text-base leading-relaxed"
        >
            Estudiante de desarrollo web con ganas de aprender nuevas
            tecnologías y ampliar mis conocimientos y habilidades
        </p>
        <!-- Pills de RRSS -->
        <section
            class="flex gap-2 sm:gap-3 md:gap-4 flex-wrap justify-center max-w-full"
        >
            <!-- Uso de icon el import como variable (Se usar .src para obtener el link) -->
            <Media
                nombre="Github"
                link="https://github.com/new-CarlosEst"
                icon={GithubIcon.src}
            />
            <Media
                nombre="LinkedIn"
                link="https://www.linkedin.com/in/new-carlosest/"
                icon={LinkedInIcon.src}
            />
            <Media
                nombre="Stackoverflow"
                link="https://stackoverflow.com/users/31797554/new-carlosest"
                icon={StackoverflowIcon.src}
            />
        </section>

        <!-- Botones con el contacto y el CV -->
        <div
            class="flex flex-col sm:flex-row gap-3 sm:gap-4 font-medium w-full sm:w-auto px-6 sm:px-0"
        >
            <a
                href="/Cv-CarlosEstebanDiez.pdf"
                download
                class="bg-blue-500 text-white rounded px-4 py-2 hover:bg-blue-700 transition-colors text-center text-sm sm:text-base"
                >Descargar CV</a
            >
            <button
                class="rounded px-4 py-2 border border-gray-500 bg-transparent text-white hover:bg-gray-500/20 transition-colors text-sm sm:text-base"
                ><a href="#contact">Contáctame</a></button
            >
        </div>
    </div>
</main>
