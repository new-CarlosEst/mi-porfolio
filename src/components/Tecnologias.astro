---
    const { nombre, icon } = Astro.props;
---

<section class="inline-flex items-center gap-2 border border-gray-300/20 rounded bg-gray-800 text-white px-2 py-1
    hover:border-blue-500 hover:text-blue-500 hover:scale-110 hover:-translate-y-1 transition-all duration-200">
    <img src={icon} alt={`${nombre} icon`} class="w-4 h-4 filter brightness-0 invert" />
    <p>{nombre}</p>
</section>