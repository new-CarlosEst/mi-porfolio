---
const { nombre, icon } = Astro.props;
---

<section
    class="tech-badge inline-flex items-center gap-2 border border-gray-300/20 rounded bg-zinc-900 text-white px-2 py-1
    hover:border-blue-500 hover:text-blue-500 hover:scale-110 hover:-translate-y-1 transition-all duration-200"
>
    <div class="tech-icon w-4 h-4" set:html={icon} />
    <p>{nombre}</p>
</section>

<style>
    .tech-icon :global(svg) {
        width: 100%;
        height: 100%;
        display: block;
    }

    .tech-icon :global(svg [stroke]) {
        stroke: white;
    }

    .tech-icon :global(svg [fill]:not([fill="none"])) {
        fill: white;
    }

    .tech-badge:hover .tech-icon :global(svg [stroke]) {
        stroke: #3b82f6;
    }

    .tech-badge:hover .tech-icon :global(svg [fill]:not([fill="none"])) {
        fill: #3b82f6;
    }
</style>
